rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Anyone can read images and resume PDFs
      allow read: if true;
      // Only the authenticated admin user can upload/modify files
      allow write: if request.auth != null && (request.auth.token.email == 'karanak1513@gmail.com' || request.auth.token.email == 'karankartik0251@gmail.com');
    }
  }
}
